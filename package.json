{
  "name": "photo-carousel-demo",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve photo-carousel-demo",
    "build": "ng build photo-carousel-demo",
    "watch": "ng build photo-carousel-demo --watch --configuration development",
    "test": "ng test photo-carousel-demo --watch=false --browsers=ChromeHeadless && ng test mat-image-carousel --watch=false --browsers=ChromeHeadless",
    "build:lib": "ng build mat-image-carousel",
    "pack:lib": "npm run build:lib && cd dist/mat-image-carousel && npm pack",
    "publish:lib": "npm run build:lib && cd dist/mat-image-carousel && npm publish",
    "lint": "ng lint photo-carousel-demo && ng lint mat-image-carousel"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/material": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "22.0.0",
    "eslint": "^9.39.2",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^22.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.61.0"
  }
}
